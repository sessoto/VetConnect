# Database
DATABASE_URL="postgresql://vetconnect:vetconnect@localhost:5432/vetconnect?schema=public"

# API server
PORT=3000
NODE_ENV=development

# JWT secrets (generate strong values for production: `openssl rand -base64 48`)
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d

# Expo Push (optional in dev; required to actually deliver push)
EXPO_ACCESS_TOKEN=

# Mobile (Expo) — points to running API
EXPO_PUBLIC_API_URL=http://localhost:3000
